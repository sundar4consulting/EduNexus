// Prisma Schema for EduNexus Platform
// PostgreSQL database with full schema for all modules

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id               String    @id @default(uuid()) @db.Uuid
  email            String    @unique @db.VarChar(255)
  passwordHash     String    @map("password_hash") @db.VarChar(255)
  name             String    @db.VarChar(255)
  avatarUrl        String?   @map("avatar_url")
  role             Role      @default(STUDENT)
  collegeId        String?   @map("college_id") @db.Uuid
  branch           String?   @db.VarChar(100)
  yearOfStudy      Int?      @map("year_of_study")
  bio              String?
  phone            String?   @db.VarChar(20)
  linkedinUrl      String?   @map("linkedin_url")
  githubUrl        String?   @map("github_url")
  karmaPoints      Int       @default(0) @map("karma_points")
  xp               Int       @default(0)
  level            Int       @default(1)
  currentStreak    Int       @default(0) @map("current_streak")
  longestStreak    Int       @default(0) @map("longest_streak")
  lastActiveDate   DateTime? @map("last_active_date") @db.Date
  subscriptionTier Tier      @default(FREE) @map("subscription_tier")
  isVerified       Boolean   @default(false) @map("is_verified")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  college           College?           @relation(fields: [collegeId], references: [id])
  enrollments       Enrollment[]
  lessonProgress    LessonProgress[]
  quizAttempts      QuizAttempt[]
  codeSubmissions   CodeSubmission[]
  eventRegistrations EventRegistration[]
  certificates      Certificate[]
  subscriptions     Subscription[]
  notifications     Notification[]
  createdCourses    Course[]           @relation("InstructorCourses")
  createdPaths      LearningPath[]     @relation("PathCreator")
  createdQuizzes    Quiz[]             @relation("QuizCreator")
  createdProblems   CodingProblem[]    @relation("ProblemCreator")
  createdEvents     Event[]            @relation("EventCreator")
  jobApplications   JobApplication[]
  forumPosts        ForumPost[]
  forumComments     ForumComment[]
  refreshTokens     RefreshToken[]
  badges            UserBadge[]
  karmaLogs         KarmaLog[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

enum Role {
  STUDENT
  FACULTY
  TPO
  ADMIN
}

enum Tier {
  FREE
  PRO
  ELITE
  INSTITUTION
}

// ============================================================
// COLLEGES (B2B)
// ============================================================

model College {
  id                    String   @id @default(uuid()) @db.Uuid
  name                  String   @db.VarChar(500)
  code                  String?  @unique @db.VarChar(50)
  city                  String?  @db.VarChar(100)
  state                 String?  @db.VarChar(100)
  universityAffiliation String?  @map("university_affiliation") @db.VarChar(500)
  logoUrl               String?  @map("logo_url")
  customDomain          String?  @map("custom_domain") @db.VarChar(255)
  subscriptionPlan      String?  @map("subscription_plan") @db.VarChar(50)
  maxStudents           Int?     @map("max_students")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz()

  users User[]

  @@map("colleges")
}

// ============================================================
// LEARNING PATHS
// ============================================================

model LearningPath {
  id            String   @id @default(uuid()) @db.Uuid
  title         String   @db.VarChar(500)
  slug          String   @unique @db.VarChar(500)
  description   String?
  category      String?  @db.VarChar(100)
  difficulty    String?  @db.VarChar(20)
  estimatedHours Int?    @map("estimated_hours")
  thumbnailUrl  String?  @map("thumbnail_url")
  isPublished   Boolean  @default(false) @map("is_published")
  enrolledCount Int      @default(0) @map("enrolled_count")
  createdBy     String?  @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  creator       User?              @relation("PathCreator", fields: [createdBy], references: [id])
  pathCourses   LearningPathCourse[]

  @@map("learning_paths")
}

model LearningPathCourse {
  id             String @id @default(uuid()) @db.Uuid
  learningPathId String @map("learning_path_id") @db.Uuid
  courseId        String @map("course_id") @db.Uuid
  positionX      Int    @default(0) @map("position_x")
  positionY      Int    @default(0) @map("position_y")
  isMilestone    Boolean @default(false) @map("is_milestone")
  sortOrder      Int    @default(0) @map("sort_order")

  learningPath LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("learning_path_courses")
}

// ============================================================
// COURSES
// ============================================================

model Course {
  id              String   @id @default(uuid()) @db.Uuid
  title           String   @db.VarChar(500)
  slug            String   @unique @db.VarChar(500)
  description     String?
  thumbnailUrl    String?  @map("thumbnail_url")
  instructorId    String?  @map("instructor_id") @db.Uuid
  category        String?  @db.VarChar(100)
  difficulty      String?  @db.VarChar(20)
  estimatedHours  Int?     @map("estimated_hours")
  tierRequired    Tier     @default(FREE) @map("tier_required")
  isPublished     Boolean  @default(false) @map("is_published")
  enrolledCount   Int      @default(0) @map("enrolled_count")
  avgRating       Decimal  @default(0) @map("avg_rating") @db.Decimal(3, 2)
  tags            String[]
  learningOutcomes String[] @map("learning_outcomes")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  instructor     User?              @relation("InstructorCourses", fields: [instructorId], references: [id])
  modules        CourseModule[]
  enrollments    Enrollment[]
  quizzes        Quiz[]
  pathCourses    LearningPathCourse[]

  @@map("courses")
}

model CourseModule {
  id        String   @id @default(uuid()) @db.Uuid
  courseId   String   @map("course_id") @db.Uuid
  title     String   @db.VarChar(500)
  sortOrder Int      @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]
  quizzes Quiz[]

  @@map("course_modules")
}

model Lesson {
  id              String   @id @default(uuid()) @db.Uuid
  moduleId        String   @map("module_id") @db.Uuid
  title           String   @db.VarChar(500)
  type            LessonType
  contentUrl      String?  @map("content_url")
  contentMarkdown String?  @map("content_markdown")
  durationMinutes Int?     @map("duration_minutes")
  sortOrder       Int      @map("sort_order")
  isFreePreview   Boolean  @default(false) @map("is_free_preview")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  module         CourseModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  lessonProgress LessonProgress[]

  @@map("lessons")
}

enum LessonType {
  VIDEO
  ARTICLE
  INTERACTIVE
  LAB
}

// ============================================================
// ENROLLMENTS & PROGRESS
// ============================================================

model Enrollment {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  courseId        String    @map("course_id") @db.Uuid
  enrolledAt     DateTime  @default(now()) @map("enrolled_at") @db.Timestamptz()
  completedAt    DateTime? @map("completed_at") @db.Timestamptz()
  progressPercent Int      @default(0) @map("progress_percent")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("enrollments")
}

model LessonProgress {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  lessonId        String    @map("lesson_id") @db.Uuid
  completed       Boolean   @default(false)
  completedAt     DateTime? @map("completed_at") @db.Timestamptz()
  timeSpentSeconds Int      @default(0) @map("time_spent_seconds")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

// ============================================================
// QUIZZES & ASSESSMENTS
// ============================================================

model Quiz {
  id                 String   @id @default(uuid()) @db.Uuid
  title              String   @db.VarChar(500)
  courseId            String?  @map("course_id") @db.Uuid
  moduleId           String?  @map("module_id") @db.Uuid
  type               QuizType @default(PRACTICE)
  timeLimitMinutes   Int?     @map("time_limit_minutes")
  maxAttempts        Int      @default(3) @map("max_attempts")
  passingScorePercent Int     @default(60) @map("passing_score_percent")
  shuffleQuestions   Boolean  @default(true) @map("shuffle_questions")
  isPublished        Boolean  @default(false) @map("is_published")
  createdBy          String?  @map("created_by") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz()

  course    Course?       @relation(fields: [courseId], references: [id])
  module    CourseModule? @relation(fields: [moduleId], references: [id])
  creator   User?         @relation("QuizCreator", fields: [createdBy], references: [id])
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@map("quizzes")
}

model QuizQuestion {
  id            String  @id @default(uuid()) @db.Uuid
  quizId        String  @map("quiz_id") @db.Uuid
  type          String  @db.VarChar(20)
  text          String
  codeSnippet   String? @map("code_snippet")
  imageUrl      String? @map("image_url")
  options       Json?
  correctAnswer String? @map("correct_answer")
  explanation   String?
  difficulty    String? @db.VarChar(20)
  points        Int     @default(10)
  sortOrder     Int?    @map("sort_order")
  tags          String[]

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model QuizAttempt {
  id          String    @id @default(uuid()) @db.Uuid
  quizId      String    @map("quiz_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  startedAt   DateTime  @default(now()) @map("started_at") @db.Timestamptz()
  completedAt DateTime? @map("completed_at") @db.Timestamptz()
  score       Int       @default(0)
  maxScore    Int?      @map("max_score")
  percentage  Decimal?  @db.Decimal(5, 2)
  passed      Boolean?
  answers     Json?
  karmaAwarded Int      @default(0) @map("karma_awarded")

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("quiz_attempts")
}

enum QuizType {
  PRACTICE
  GRADED
  CONTEST
  MOCK_TEST
}

// ============================================================
// CODING PROBLEMS & SUBMISSIONS
// ============================================================

model CodingProblem {
  id                  String  @id @default(uuid()) @db.Uuid
  title               String  @db.VarChar(500)
  slug                String  @unique @db.VarChar(500)
  descriptionMarkdown String  @map("description_markdown")
  difficulty          String  @db.VarChar(20)
  category            String? @db.VarChar(100)
  tags                String[]
  companies           String[]
  constraints         String?
  inputFormat         String? @map("input_format")
  outputFormat        String? @map("output_format")
  examples            Json?
  testCases           Json?   @map("test_cases")
  editorialMarkdown   String? @map("editorial_markdown")
  hints               String[]
  submissionCount     Int     @default(0) @map("submission_count")
  acceptanceRate      Decimal @default(0) @map("acceptance_rate") @db.Decimal(5, 2)
  createdBy           String? @map("created_by") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz()

  creator     User?            @relation("ProblemCreator", fields: [createdBy], references: [id])
  submissions CodeSubmission[]

  @@map("coding_problems")
}

model CodeSubmission {
  id              String   @id @default(uuid()) @db.Uuid
  problemId       String   @map("problem_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  language        String   @db.VarChar(20)
  code            String
  status          String   @db.VarChar(10)
  executionTimeMs Int?     @map("execution_time_ms")
  memoryUsedMb    Decimal? @map("memory_used_mb") @db.Decimal(10, 2)
  testCasesPassed Int?     @map("test_cases_passed")
  totalTestCases  Int?     @map("total_test_cases")
  aiFeedback      String?  @map("ai_feedback")
  karmaAwarded    Int      @default(0) @map("karma_awarded")
  submittedAt     DateTime @default(now()) @map("submitted_at") @db.Timestamptz()

  problem CodingProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("code_submissions")
}

// ============================================================
// EVENTS
// ============================================================

model Event {
  id                   String      @id @default(uuid()) @db.Uuid
  title                String      @db.VarChar(500)
  slug                 String      @unique @db.VarChar(500)
  description          String?
  type                 String      @db.VarChar(30)
  bannerImageUrl       String?     @map("banner_image_url")
  startTime            DateTime    @map("start_time") @db.Timestamptz()
  endTime              DateTime    @map("end_time") @db.Timestamptz()
  isOnline             Boolean     @default(true) @map("is_online")
  venueOrLink          String?     @map("venue_or_link")
  maxParticipants      Int?        @map("max_participants")
  currentRegistrations Int         @default(0) @map("current_registrations")
  tierRequired         Tier        @default(FREE) @map("tier_required")
  speakers             Json?
  agenda               Json?
  tags                 String[]
  recordingUrl         String?     @map("recording_url")
  karmaAward           Int         @default(10) @map("karma_award")
  status               EventStatus @default(UPCOMING)
  createdBy            String?     @map("created_by") @db.Uuid
  createdAt            DateTime    @default(now()) @map("created_at") @db.Timestamptz()

  creator       User?               @relation("EventCreator", fields: [createdBy], references: [id])
  registrations EventRegistration[]

  @@map("events")
}

model EventRegistration {
  id             String    @id @default(uuid()) @db.Uuid
  eventId        String    @map("event_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  registeredAt   DateTime  @default(now()) @map("registered_at") @db.Timestamptz()
  attended       Boolean   @default(false)
  feedbackRating Int?      @map("feedback_rating")
  feedbackText   String?   @map("feedback_text")
  certificateId  String?   @map("certificate_id") @db.Uuid

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("event_registrations")
}

enum EventStatus {
  UPCOMING
  LIVE
  COMPLETED
  CANCELLED
}

// ============================================================
// JOBS
// ============================================================

model Job {
  id                  String   @id @default(uuid()) @db.Uuid
  title               String   @db.VarChar(500)
  companyName         String   @map("company_name") @db.VarChar(255)
  companyLogoUrl      String?  @map("company_logo_url")
  description         String?
  requirements        String[]
  niceToHave          String[] @map("nice_to_have")
  jobType             String   @map("job_type") @db.VarChar(20)
  location            String?  @db.VarChar(255)
  isRemote            Boolean  @default(false) @map("is_remote")
  salaryRange         String?  @map("salary_range") @db.VarChar(100)
  experienceRequired  String?  @map("experience_required") @db.VarChar(50)
  branchesEligible    String[] @map("branches_eligible")
  applicationDeadline DateTime? @map("application_deadline") @db.Timestamptz()
  postedAt            DateTime @default(now()) @map("posted_at") @db.Timestamptz()
  applyUrl            String?  @map("apply_url")
  status              String   @default("active") @db.VarChar(20)

  applications JobApplication[]

  @@map("jobs")
}

model JobApplication {
  id        String   @id @default(uuid()) @db.Uuid
  jobId     String   @map("job_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  resumeUrl String?  @map("resume_url")
  coverNote String?  @map("cover_note")
  status    String   @default("applied") @db.VarChar(20)
  appliedAt DateTime @default(now()) @map("applied_at") @db.Timestamptz()

  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
  @@map("job_applications")
}

// ============================================================
// CERTIFICATES
// ============================================================

model Certificate {
  id               String    @id @default(uuid()) @db.Uuid
  verificationCode String    @unique @map("verification_code") @db.VarChar(50)
  userId           String    @map("user_id") @db.Uuid
  type             String    @db.VarChar(50)
  title            String    @db.VarChar(500)
  description      String?
  courseId          String?   @map("course_id") @db.Uuid
  eventId          String?   @map("event_id") @db.Uuid
  issuedAt         DateTime  @default(now()) @map("issued_at") @db.Timestamptz()
  expiresAt        DateTime? @map("expires_at") @db.Timestamptz()
  metadata         Json?
  templateId       String?   @map("template_id") @db.VarChar(50)
  pdfUrl           String?   @map("pdf_url")
  imageUrl         String?   @map("image_url")
  isRevoked        Boolean   @default(false) @map("is_revoked")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("certificates")
}

// ============================================================
// SUBSCRIPTIONS & BILLING
// ============================================================

model Subscription {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  plan             String   @db.VarChar(20)
  billingCycle     String   @map("billing_cycle") @db.VarChar(20)
  amount           Decimal  @db.Decimal(10, 2)
  currency         String   @default("INR") @db.VarChar(10)
  tax              Decimal? @db.Decimal(10, 2)
  paymentGateway   String?  @map("payment_gateway") @db.VarChar(50)
  transactionId    String?  @map("transaction_id") @db.VarChar(255)
  startedAt        DateTime @default(now()) @map("started_at") @db.Timestamptz()
  currentPeriodEnd DateTime @map("current_period_end") @db.Timestamptz()
  status           String   @default("active") @db.VarChar(20)
  cancelReason     String?  @map("cancel_reason")
  autoRenew        Boolean  @default(true) @map("auto_renew")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ============================================================
// BADGES & ACHIEVEMENTS
// ============================================================

model Badge {
  id          String @id @default(uuid()) @db.Uuid
  name        String @db.VarChar(255)
  slug        String @unique @db.VarChar(255)
  description String?
  iconUrl     String? @map("icon_url")
  category    String? @db.VarChar(50)
  criteria    Json?

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  badgeId  String   @map("badge_id") @db.Uuid
  earnedAt DateTime @default(now()) @map("earned_at") @db.Timestamptz()

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

// ============================================================
// KARMA LOG
// ============================================================

model KarmaLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  action    String   @db.VarChar(100)
  points    Int
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("karma_logs")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(500)
  message   String
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ============================================================
// COMMUNITY / FORUMS
// ============================================================

model ForumPost {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String   @db.VarChar(500)
  content   String
  category  String?  @db.VarChar(100)
  tags      String[]
  upvotes   Int      @default(0)
  downvotes Int      @default(0)
  isPinned  Boolean  @default(false) @map("is_pinned")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments ForumComment[]

  @@map("forum_posts")
}

model ForumComment {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  content   String
  upvotes   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("forum_comments")
}
